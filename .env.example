# ============================================================
# Vinmec AI Agent Demo — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# PostgreSQL connection string (Docker Compose or external)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vinmec_ai?schema=public"

# OpenAI API Key (required for gpt-4o-mini)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Next.js public URL (for production)
NEXT_PUBLIC_APP_URL="https://nhom62.lab6.vinmec.hvan.it.com"

# App display name
NEXT_PUBLIC_APP_NAME="Trợ lý ảo VinmecCare"

# Optional: NextAuth secret (if adding auth later)
# NEXTAUTH_SECRET="your-secret-here"
# NEXTAUTH_URL="http://localhost:3000"

# Admin dashboard key (simple query-string token for demo)
# Access: /admin/feedback?key=vinmec-demo-2026
ADMIN_KEY="vinmec-demo-2026"

# ──────────────────────────────────────────────────────────────
# Cloudflare Tunnel Token
# Tạo tunnel tại: https://dash.cloudflare.com → Zero Trust → Networks → Tunnels
# Public hostname: nhom62.lab6.vinmec.hvan.it.com → http://localhost:3000
# ──────────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN="eyJ..."
